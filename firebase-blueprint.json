{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A freelance project",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "client": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "In Progress", "Completed"] },
        "progress": { "type": "number" },
        "deadline": { "type": "string", "format": "date" },
        "userId": { "type": "string" }
      },
      "required": ["name", "client", "status", "userId"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["amount", "type", "date", "userId"]
    },
    "Goal": {
      "title": "Goal",
      "description": "A financial or project goal",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "target": { "type": "number" },
        "current": { "type": "number" },
        "deadline": { "type": "string", "format": "date" },
        "userId": { "type": "string" }
      },
      "required": ["title", "target", "userId"]
    },
    "Note": {
      "title": "Note",
      "description": "A daily note or thought",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["content", "date", "userId"]
    },
    "Workout": {
      "title": "Workout",
      "description": "A gym workout session",
      "type": "object",
      "properties": {
        "exercise": { "type": "string" },
        "sets": { "type": "number" },
        "reps": { "type": "number" },
        "weight": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "userId": { "type": "string" }
      },
      "required": ["exercise", "sets", "reps", "userId"]
    },
    "Checklist": {
      "title": "Checklist Item",
      "description": "A workout task or habit",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "completed": { "type": "boolean" },
        "userId": { "type": "string" }
      },
      "required": ["text", "completed", "userId"]
    },
    "Client": {
      "title": "Client",
      "description": "A professional contact",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "company": { "type": "string" },
        "phone": { "type": "string" },
        "notes": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["name", "userId"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "A client invoice",
      "type": "object",
      "properties": {
        "invoiceNumber": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["Draft", "Sent", "Paid", "Overdue"] },
        "dueDate": { "type": "string", "format": "date" },
        "items": { "type": "array" },
        "userId": { "type": "string" }
      },
      "required": ["invoiceNumber", "clientId", "amount", "status", "userId"]
    }
  },
  "firestore": {
    "/projects/{projectId}": { "schema": "Project", "description": "User projects" },
    "/transactions/{transactionId}": { "schema": "Transaction", "description": "Financial records" },
    "/goals/{goalId}": { "schema": "Goal", "description": "User goals" },
    "/notes/{noteId}": { "schema": "Note", "description": "Daily notes" },
    "/workouts/{workoutId}": { "schema": "Workout", "description": "Gym workouts" },
    "/clients/{clientId}": { "schema": "Client", "description": "Client contacts" },
    "/checklists/{checklistId}": { "schema": "Checklist", "description": "Workout habits/tasks" }
  }
}
